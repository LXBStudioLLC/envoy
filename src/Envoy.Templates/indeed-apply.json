{
  "id": "indeed-apply",
  "name": "Indeed Easy Apply",
  "url_match": "indeed.com/viewjob*",
  "version": "1.0.0",
  "steps": [
    {
      "action": "wait_for",
      "selector": "button[aria-label='Apply now']",
      "timeout": 10000
    },
    {
      "action": "click",
      "selector": "button[aria-label='Apply now']",
      "fingerprint": {
        "tag": "button",
        "attributes": {
          "aria-label": "Apply now"
        },
        "label_text": "Apply now",
        "text_content": "Apply now",
        "ancestor_chain": ["div.jobsearch-ViewJobLayout"],
        "position_index": 0
      }
    },
    {
      "action": "wait_for",
      "selector": "input[type='email']",
      "timeout": 5000
    },
    {
      "action": "fill",
      "field_id": "email",
      "selector": "input[type='email']",
      "fingerprint": {
        "tag": "input",
        "attributes": {
          "type": "email",
          "name": "email"
        },
        "label_text": "Email Address",
        "ancestor_chain": ["div.ia-ApplyFormWrapper", "div.ia-FormField"],
        "position_index": 0
      }
    },
    {
      "action": "upload",
      "field_id": "resume",
      "selector": "input[type='file']",
      "value_from": "generated_pdf_path",
      "fingerprint": {
        "tag": "input",
        "attributes": {
          "type": "file",
          "name": "resume"
        },
        "label_text": "Resume",
        "ancestor_chain": ["div.ia-ApplyFormWrapper", "div.ia-FormField"],
        "position_index": 1
      }
    },
    {
      "action": "conditional_click",
      "description": "Continue to review",
      "selector": "button[data-testid='continue-button']",
      "require_confirmation": false,
      "fingerprint": {
        "tag": "button",
        "attributes": {
          "data-testid": "continue-button"
        },
        "label_text": "Continue",
        "text_content": "Continue",
        "ancestor_chain": ["div.ia-ApplyFormWrapper"],
        "siblings_before": ["Email Address", "Resume"],
        "position_index": 2
      }
    },
    {
      "action": "conditional_click",
      "description": "Submit Indeed application",
      "selector": "button[data-testid='submit-button']",
      "require_confirmation": true,
      "fingerprint": {
        "tag": "button",
        "attributes": {
          "data-testid": "submit-button"
        },
        "label_text": "Submit",
        "text_content": "Submit Application",
        "ancestor_chain": ["div.ia-ApplyFormWrapper"],
        "siblings_before": ["Continue"],
        "position_index": 3
      }
    }
  ]
}