<UserControl x:Class="Envoy.UI.LLMSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0A0E17">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24">
            <TextBlock Text="&#x25C8; LLM NEXUS" Style="{StaticResource CyberHeading}" Margin="0,0,0,4"/>
            <TextBlock Text="CONFIGURE YOUR AI CO-PROCESSOR &#x2014; LOCAL OR CLOUD" Style="{StaticResource CyberSubheading}" Margin="0,0,0,20"/>

            <Border Background="#111827" CornerRadius="3" BorderBrush="#1A3A4A" BorderThickness="1" Padding="16" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect Color="#00F0FF" BlurRadius="12" ShadowDepth="0" Opacity="0.15"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="&#x26A0; ALL PROCESSING IS LOCAL BY DEFAULT" Foreground="#39FF14" FontSize="12" FontWeight="Bold" FontFamily="{StaticResource CyberFontHeading}" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#8892A4" FontSize="11" FontFamily="{StaticResource CyberFontBody}" Margin="0,0,0,4">
                        Envoy uses local LLMs for resume tailoring. Your data never leaves your machine unless you configure a cloud provider. Ollama and LM Studio are both auto-detected.
                    </TextBlock>
                </StackPanel>
            </Border>

            <TextBlock Text="ACTIVE PROVIDER" Foreground="#00F0FF" FontSize="14" FontWeight="Bold" FontFamily="{StaticResource CyberFontHeading}" Margin="0,0,0,8"/>

            <Border Background="#111827" CornerRadius="3" BorderBrush="#1A3A4A" BorderThickness="1" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ActiveProviderLabel" Text="Detecting..." Foreground="#E0E6F0" FontSize="14" FontWeight="Bold" FontFamily="{StaticResource CyberFontBody}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ActiveModelLabel" Text="" Foreground="#8892A4" FontSize="11" FontFamily="{StaticResource CyberFontBody}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>
                    <TextBlock x:Name="ConnectionStatusLabel" Text="Scanning for local LLMs..." Foreground="#8892A4" FontSize="11" FontFamily="{StaticResource CyberFontBody}" Margin="0,0,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Text="DETECTED PROVIDERS" Foreground="#00F0FF" FontSize="14" FontWeight="Bold" FontFamily="{StaticResource CyberFontHeading}" Margin="0,0,0,12"/>

            <ItemsControl x:Name="ProviderList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#111827" CornerRadius="3" BorderThickness="2" Padding="16" Margin="0,0,0,10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#1A3A4A"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="BorderBrush" Value="#00F0FF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.Effect>
                                <DropShadowEffect Color="#00F0FF" BlurRadius="10" ShadowDepth="0" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock FontSize="15" FontWeight="Bold" Foreground="#E0E6F0" FontFamily="{StaticResource CyberFontBody}" Text="{Binding ProviderName}"/>
                                            <TextBlock FontSize="11" Foreground="#8892A4" FontFamily="{StaticResource CyberFontBody}" Margin="8,0,0,0" VerticalAlignment="Center" Text="{Binding Endpoint}"/>
                                        </StackPanel>
                                        <TextBlock FontSize="11" Foreground="#8892A4" FontFamily="{StaticResource CyberFontBody}" Margin="0,0,0,2">
                                            <Run Text="STATUS: "/><Run Text="{Binding StatusText}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="#8892A4" FontFamily="{StaticResource CyberFontBody}" Margin="0,0,0,2">
                                            <Run Text="MODELS: "/><Run Text="{Binding ModelCountText}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <Button Content="&#x25C8; ACTIVATE" Click="ActivateProvider_Click" Style="{StaticResource CyberButton}" Padding="12,6" FontSize="11" Margin="0,0,0,4" Tag="{Binding ProviderId}"/>
                                        <Button Content="&#x25B6; TEST" Click="TestProvider_Click" Style="{StaticResource CyberButton}" Padding="12,6" FontSize="11" Margin="0,0,0,4" Tag="{Binding ProviderId}"/>
                                        <Button Content="&#x21BB; SCAN" Click="ScanProvider_Click" Style="{StaticResource CyberButton}" Padding="12,6" FontSize="11" Tag="{Binding ProviderId}"/>
                                    </StackPanel>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Models}" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0D1321" CornerRadius="2" Padding="8,4" Margin="0,0,0,4" Cursor="Hand" MouseLeftButtonUp="Model_Click">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock FontSize="11" FontWeight="Bold" Foreground="#E0E6F0" FontFamily="{StaticResource CyberFontBody}" Text="{Binding DisplayName}"/>
                                                        <TextBlock FontSize="10" Foreground="#8892A4" FontFamily="{StaticResource CyberFontBody}">
                                                            <Run Text="{Binding SizeDisplay}"/><Run Text=" | "/><Run Text="{Binding Quantization, StringFormat='Q: {0}'}"/><Run Text="{Binding Family, StringFormat=' | {0}'}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" FontSize="9" Foreground="#8892A4" FontFamily="{StaticResource CyberFontBody}" Text="{Binding Recommendation}" TextWrapping="Wrap" MaxWidth="250" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock x:Name="NoProviderLabel" Text="NO LLM PROVIDERS DETECTED &#x2014; Install Ollama or LM Studio, or configure a cloud API key below" Foreground="#FF073A" FontSize="12" FontFamily="{StaticResource CyberFontBody}" Visibility="Collapsed" Margin="0,8"/>
            <TextBlock x:Name="ProviderNoteLabel" Text="" Foreground="#8892A4" FontSize="11" FontFamily="{StaticResource CyberFontBody}" Visibility="Collapsed" Margin="0,4,0,0"/>

            <TextBlock Text="CLOUD API CONFIGURATION" Foreground="#00F0FF" FontSize="14" FontWeight="Bold" FontFamily="{StaticResource CyberFontHeading}" Margin="0,24,0,8"/>
            <TextBlock Text="Optional. Your data will be sent to the cloud provider if configured." Foreground="#8892A4" FontSize="11" FontFamily="{StaticResource CyberFontBody}" Margin="0,0,0,12"/>

            <Border Background="#111827" CornerRadius="3" BorderBrush="#1A3A4A" BorderThickness="1" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Ollama Port:" Foreground="#8892A4" FontSize="12" FontFamily="{StaticResource CyberFontBody}" VerticalAlignment="Center"/>
                        <TextBox x:Name="OllamaEndpointBox" Style="{StaticResource CyberTextBox}" Grid.Column="1" Text="http://localhost:11434"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="LM Studio Port:" Foreground="#8892A4" FontSize="12" FontFamily="{StaticResource CyberFontBody}" VerticalAlignment="Center"/>
                        <TextBox x:Name="LmStudioPortBox" Style="{StaticResource CyberTextBox}" Grid.Column="1" Text="1234"/>
                    </Grid>

                    <Rectangle Fill="#1A3A4A" Height="1" Margin="0,4,0,12"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="OpenAI Key:" Foreground="#8892A4" FontSize="12" FontFamily="{StaticResource CyberFontBody}" VerticalAlignment="Center"/>
                        <PasswordBox x:Name="OpenAIKeyBox" Grid.Column="1" Background="#0D1321" Foreground="#E0E6F0" BorderBrush="#1A3A4A" BorderThickness="1" Padding="8,6" FontFamily="{StaticResource CyberFontBody}" FontSize="12"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Anthropic Key:" Foreground="#8892A4" FontSize="12" FontFamily="{StaticResource CyberFontBody}" VerticalAlignment="Center"/>
                        <PasswordBox x:Name="AnthropicKeyBox" Grid.Column="1" Background="#0D1321" Foreground="#E0E6F0" BorderBrush="#1A3A4A" BorderThickness="1" Padding="8,6" FontFamily="{StaticResource CyberFontBody}" FontSize="12"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Gemini Key:" Foreground="#8892A4" FontSize="12" FontFamily="{StaticResource CyberFontBody}" VerticalAlignment="Center"/>
                        <PasswordBox x:Name="GeminiKeyBox" Grid.Column="1" Background="#0D1321" Foreground="#E0E6F0" BorderBrush="#1A3A4A" BorderThickness="1" Padding="8,6" FontFamily="{StaticResource CyberFontBody}" FontSize="12"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="BtnSaveConfig" Content="&#x25C8; SAVE CONFIGURATION" Click="BtnSaveConfig_Click" Style="{StaticResource CyberButton}" Padding="16,8" Margin="0,0,8,0"/>
                        <Button x:Name="BtnRescan" Content="&#x25B6; RESCAN ALL" Click="BtnRescan_Click" Style="{StaticResource CyberButton}" Padding="16,8"/>
                    </StackPanel>

                    <TextBlock x:Name="ConfigSaveStatus" Text="" Foreground="#39FF14" FontSize="11" FontFamily="{StaticResource CyberFontBody}" Margin="0,8,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>