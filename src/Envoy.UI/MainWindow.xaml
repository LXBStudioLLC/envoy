<Window x:Class="Envoy.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ENVOY" Width="1100" Height="750" MinWidth="900" MinHeight="600"
        WindowStyle="None" AllowsTransparency="True" Background="#0A0E17" Foreground="#E0E6F0"
        FontFamily="{StaticResource CyberFontBody}" FontSize="13" ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown" Loaded="Window_Loaded">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Border BorderBrush="#00F0FF" BorderThickness="1" CornerRadius="0">
        <Border.Effect>
            <DropShadowEffect Color="#00F0FF" BlurRadius="16" ShadowDepth="0" Opacity="0.15"/>
        </Border.Effect>
        <Grid Background="#0A0E17">
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#0D1117">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Text="&#x25C8; ENVOY" FontSize="16" FontWeight="Bold" Foreground="#00F0FF" FontFamily="{StaticResource CyberFontHeading}" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00F0FF" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock x:Name="VersionText" Text=" SOVEREIGN JOB AGENT" FontSize="11" Foreground="#8892A4" FontFamily="{StaticResource CyberFontBody}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                    <Button x:Name="BtnAbout" Content="?" Width="36" Height="36" Click="BtnAbout_Click" Background="Transparent" Foreground="#8892A4" BorderThickness="0" FontSize="14" FontFamily="{StaticResource CyberFontBody}" AutomationProperties.Name="About and report a bug" ToolTip="About / Report a bug"/>
                    <Button x:Name="BtnMinimize" Content="&#x2500;" Width="36" Height="36" Click="BtnMinimize_Click" Background="Transparent" Foreground="#8892A4" BorderThickness="0" FontSize="14" FontFamily="{StaticResource CyberFontBody}" AutomationProperties.Name="Minimize window" ToolTip="Minimize"/>
                    <Button x:Name="BtnClose" Content="&#x2715;" Width="36" Height="36" Click="BtnClose_Click" Background="Transparent" Foreground="#FF073A" BorderThickness="0" FontSize="14" FontFamily="{StaticResource CyberFontBody}" AutomationProperties.Name="Close window" ToolTip="Close"/>
                </StackPanel>
            </Grid>

            <Rectangle Grid.Row="1" Fill="#00F0FF" Opacity="0.3" Height="1"/>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Background="#0D1117" Margin="0,0,0,0">
                    <Button x:Name="NavDashboard" Content="&#x25C8; DASHBOARD" Click="NavDashboard_Click" Style="{StaticResource CyberNavButton}" Height="44" Margin="8,12,8,2" HorizontalContentAlignment="Left"/>
                    <Button x:Name="NavFind" Content="&#x2316; FIND JOBS" Click="NavFind_Click" Style="{StaticResource CyberNavButton}" Height="44" Margin="8,2,8,2" HorizontalContentAlignment="Left"/>
                    <Button x:Name="NavApply" Content="&#x25C8; APPLY" Click="NavApply_Click" Style="{StaticResource CyberNavButton}" Height="44" Margin="8,2,8,2" HorizontalContentAlignment="Left"/>
                    <Button x:Name="NavVault" Content="&#x25C8; VAULT" Click="NavVault_Click" Style="{StaticResource CyberNavButton}" Height="44" Margin="8,2,8,2" HorizontalContentAlignment="Left"/>
                    <Button x:Name="NavBrowser" Content="&#x2699; BROWSER" Click="NavBrowser_Click" Style="{StaticResource CyberNavButton}" Height="44" Margin="8,2,8,2" HorizontalContentAlignment="Left"/>
                    <Button x:Name="NavLLM" Content="&#x2699; LLM NEXUS" Click="NavLLM_Click" Style="{StaticResource CyberNavButton}" Height="44" Margin="8,2,8,2" HorizontalContentAlignment="Left"/>
                    <Rectangle Fill="#1A3A4A" Height="1" Margin="16,8"/>
                    <StackPanel x:Name="HardwarePanel" Margin="16,8">
                        <TextBlock x:Name="GpuLabel" Text="&#x25C9; GPU: Detecting..." Style="{StaticResource CyberLabel}" Margin="0,4"/>
                        <TextBlock x:Name="ModelLabel" Text="&#x25C8; Model: ..." Foreground="#8892A4" FontSize="10" FontFamily="{StaticResource CyberFontBody}" Margin="0,2"/>
                        <TextBlock x:Name="ChromeLabel" Text="&#x26A0; Chrome Offline" Foreground="#FF073A" FontSize="10" FontFamily="{StaticResource CyberFontBody}" Margin="0,2"/>
                    </StackPanel>
                </StackPanel>

                <Rectangle Grid.Column="1" Fill="#1A3A4A" Width="1" Opacity="0.5"/>

                <Grid Grid.Column="2" x:Name="ContentArea" Margin="0"/>
            </Grid>

            <Rectangle Grid.Row="0" Grid.RowSpan="3" Grid.ColumnSpan="3"
                       IsHitTestVisible="False" Opacity="0.03"
                       SnapsToDevicePixels="True">
                <Rectangle.Fill>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,4,4" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing>
                                    <GeometryDrawing.Pen>
                                        <Pen Brush="#000000" Thickness="1"/>
                                    </GeometryDrawing.Pen>
                                    <GeometryDrawing.Geometry>
                                        <LineGeometry StartPoint="0,2" EndPoint="4,2"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Border Grid.Row="0" Grid.RowSpan="3" IsHitTestVisible="False">
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.5" RadiusX="0.7" RadiusY="0.7">
                        <GradientStop Offset="0" Color="Transparent"/>
                        <GradientStop Offset="0.7" Color="Transparent"/>
                        <GradientStop Offset="1" Color="#26000000"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>
        </Grid>
    </Border>
</Window>