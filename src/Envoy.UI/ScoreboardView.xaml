<UserControl x:Class="Envoy.UI.ScoreboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0A0E17">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24">
            <TextBlock Text="SCOREBOARD" Style="{StaticResource CyberHeading}" Margin="0,0,0,4"/>
            <TextBlock Text="You vs. the job market. These numbers are on your side." Style="{StaticResource CyberSubheading}" Margin="0,0,0,20"/>

            <!-- KPI tiles -->
            <UniformGrid Columns="4" Margin="0,0,0,4">
                <Border Background="#111827" CornerRadius="3" BorderBrush="#1A3A4A" BorderThickness="1" Padding="14,12" Margin="0,0,8,0">
                    <StackPanel>
                        <Rectangle Height="2" Fill="#39FF14" Margin="0,0,0,10"/>
                        <TextBlock Text="GHOSTS DODGED" Foreground="#8892A4" FontSize="10" FontFamily="{StaticResource CyberFontBody}"/>
                        <TextBlock x:Name="DodgedValue" Text="0" Foreground="#E0E6F0" FontSize="34" FontWeight="Bold" FontFamily="{StaticResource CyberFontHeading}" Margin="0,2,0,2"/>
                        <TextBlock Text="Flagged postings you passed on" Foreground="#5A6678" FontSize="9" FontFamily="{StaticResource CyberFontBody}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Border Background="#111827" CornerRadius="3" BorderBrush="#1A3A4A" BorderThickness="1" Padding="14,12" Margin="0,0,8,0">
                    <StackPanel>
                        <Rectangle Height="2" Fill="#00F0FF" Margin="0,0,0,10"/>
                        <TextBlock Text="HOURS SAVED" Foreground="#8892A4" FontSize="10" FontFamily="{StaticResource CyberFontBody}"/>
                        <TextBlock x:Name="HoursValue" Text="0.0" Foreground="#E0E6F0" FontSize="34" FontWeight="Bold" FontFamily="{StaticResource CyberFontHeading}" Margin="0,2,0,2"/>
                        <TextBlock x:Name="HoursFormula" Text="0 dodges &#x00D7; 45 min" Foreground="#5A6678" FontSize="9" FontFamily="{StaticResource CyberFontBody}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Border Background="#111827" CornerRadius="3" BorderBrush="#1A3A4A" BorderThickness="1" Padding="14,12" Margin="0,0,8,0">
                    <StackPanel>
                        <Rectangle Height="2" Fill="#FFE600" Margin="0,0,0,10"/>
                        <TextBlock Text="DAY STREAK" Foreground="#8892A4" FontSize="10" FontFamily="{StaticResource CyberFontBody}"/>
                        <TextBlock x:Name="StreakValue" Text="0" Foreground="#E0E6F0" FontSize="34" FontWeight="Bold" FontFamily="{StaticResource CyberFontHeading}" Margin="0,2,0,2"/>
                        <TextBlock Text="Days in a row you've worked the hunt" Foreground="#5A6678" FontSize="9" FontFamily="{StaticResource CyberFontBody}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Border Background="#111827" CornerRadius="3" BorderBrush="#1A3A4A" BorderThickness="1" Padding="14,12">
                    <StackPanel>
                        <Rectangle Height="2" Fill="#FF073A" Margin="0,0,0,10"/>
                        <TextBlock Text="GHOSTS SURFACED" Foreground="#8892A4" FontSize="10" FontFamily="{StaticResource CyberFontBody}"/>
                        <TextBlock x:Name="SurfacedValue" Text="0" Foreground="#E0E6F0" FontSize="34" FontWeight="Bold" FontFamily="{StaticResource CyberFontHeading}" Margin="0,2,0,2"/>
                        <TextBlock Text="Flagged in your search results" Foreground="#5A6678" FontSize="9" FontFamily="{StaticResource CyberFontBody}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock x:Name="ContextLine" Text="" Foreground="#5A6678" FontSize="10" FontFamily="{StaticResource CyberFontBody}" Margin="2,6,0,16"/>

            <TextBlock x:Name="ColdStartLabel" Text="Nothing here yet. Run a search in Find Jobs and the board starts counting." Foreground="#8892A4" FontSize="11" FontFamily="{StaticResource CyberFontBody}" Visibility="Collapsed" Margin="2,0,0,16"/>

            <!-- Time-per-application estimate -->
            <Border Background="#0D1117" CornerRadius="3" BorderBrush="#1A3A4A" BorderThickness="1" Padding="16,12" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Your time per application:" Foreground="#8892A4" FontSize="11" FontFamily="{StaticResource CyberFontBody}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="CmbMinutes" Style="{StaticResource CyberComboBox}" SelectionChanged="CmbMinutes_SelectionChanged" AutomationProperties.Name="Minutes one application takes you">
                        <ComboBoxItem Content="15 min" Tag="15"/>
                        <ComboBoxItem Content="30 min" Tag="30"/>
                        <ComboBoxItem Content="45 min" Tag="45"/>
                        <ComboBoxItem Content="60 min" Tag="60"/>
                        <ComboBoxItem Content="90 min" Tag="90"/>
                        <ComboBoxItem Content="120 min" Tag="120"/>
                    </ComboBox>
                    <TextBlock Text="Hours saved is just dodges times this number. No invented math." Foreground="#5A6678" FontSize="10" FontFamily="{StaticResource CyberFontBody}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Receipts -->
            <Border Background="#111827" CornerRadius="3" BorderBrush="#1A3A4A" BorderThickness="1" Padding="16" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect Color="#00F0FF" BlurRadius="12" ShadowDepth="0" Opacity="0.15"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="RECEIPTS" Foreground="#00F0FF" FontSize="12" FontWeight="Bold" FontFamily="{StaticResource CyberFontHeading}" Margin="0,0,0,2"/>
                    <TextBlock Text="Every dodge, with the evidence you saw at the time" Foreground="#5A6678" FontSize="10" FontFamily="{StaticResource CyberFontBody}" Margin="0,0,0,10"/>
                    <ItemsControl x:Name="ReceiptsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A2235" CornerRadius="3" BorderBrush="#1A3A4A" BorderThickness="1" Padding="12,10" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Foreground="#E0E6F0" FontSize="12" FontFamily="{StaticResource CyberFontBody}" TextWrapping="Wrap">
                                                <Run Text="{Binding Company, Mode=OneWay}" FontWeight="Bold"/><Run Text="  &#x00B7;  "/><Run Text="{Binding Title, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding DateText}" Foreground="#5A6678" FontSize="10" FontFamily="{StaticResource CyberFontBody}" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Evidence}" Visibility="{Binding EvidenceVisibility}" Foreground="#FFE600" FontSize="10" FontFamily="{StaticResource CyberFontBody}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right">
                                            <Border Background="{Binding BadgeBrush}" CornerRadius="2" Padding="8,3" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding BadgeText}" Foreground="#0A0E17" FontSize="11" FontWeight="Bold" FontFamily="{StaticResource CyberFontHeading}"/>
                                            </Border>
                                            <Button Content="VIEW" Tag="{Binding Url}" Click="BtnViewReceipt_Click" Style="{StaticResource CyberButton}" Padding="14,5" Margin="0,8,0,0" AutomationProperties.Name="Open this dodged posting in the browser"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="NoReceiptsLabel" Text="No dodges yet. Skip a flagged posting in Find Jobs, or cancel at the submit gate, and it shows up here." Foreground="#5A6678" FontSize="10" FontFamily="{StaticResource CyberFontBody}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock x:Name="StatusLine" Text="" Foreground="#8892A4" FontSize="11" FontFamily="{StaticResource CyberFontBody}" TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
