<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="NeonCyan">#00F0FF</Color>
    <Color x:Key="NeonMagenta">#FF00FF</Color>
    <Color x:Key="NeonGreen">#39FF14</Color>
    <Color x:Key="NeonRed">#FF073A</Color>
    <Color x:Key="NeonYellow">#FFE600</Color>
    <Color x:Key="BgDark">#0A0E17</Color>
    <Color x:Key="BgPanel">#111827</Color>
    <Color x:Key="BgCard">#1A2235</Color>
    <Color x:Key="BgInput">#0D1321</Color>
    <Color x:Key="TextPrimary">#E0E6F0</Color>
    <Color x:Key="TextSecondary">#8892A4</Color>
    <Color x:Key="BorderGlow">#1A3A4A</Color>

    <SolidColorBrush x:Key="NecCyanBrush" Color="{StaticResource NeonCyan}"/>
    <SolidColorBrush x:Key="NecMagentaBrush" Color="{StaticResource NeonMagenta}"/>
    <SolidColorBrush x:Key="NecGreenBrush" Color="{StaticResource NeonGreen}"/>
    <SolidColorBrush x:Key="NecRedBrush" Color="{StaticResource NeonRed}"/>
    <SolidColorBrush x:Key="NecYellowBrush" Color="{StaticResource NeonYellow}"/>
    <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
    <SolidColorBrush x:Key="BgPanelBrush" Color="{StaticResource BgPanel}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BgInputBrush" Color="{StaticResource BgInput}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="BorderGlowBrush" Color="{StaticResource BorderGlow}"/>

    <FontFamily x:Key="CyberFontHeading">pack://application:,,,/Fonts/#Orbitron</FontFamily>
    <FontFamily x:Key="CyberFontBody">pack://application:,,,/Fonts/#JetBrains Mono</FontFamily>

    <SolidColorBrush x:Key="CyanGlow20Brush" Color="#3300F0FF"/>
    <SolidColorBrush x:Key="CyanGlow40Brush" Color="#6600F0FF"/>

    <Style x:Key="CyberWindow" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BgDarkBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource CyberFontBody}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="WindowStyle" Value="None"/>
        <Setter Property="AllowsTransparency" Value="True"/>
        <Setter Property="ResizeMode" Value="CanResizeWithGrip"/>
    </Style>

    <Style TargetType="Button" x:Key="CyberButton">
        <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource NecCyanBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource NecCyanBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="{StaticResource CyberFontBody}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="{StaticResource NeonCyan}" BlurRadius="8" ShadowDepth="0" Opacity="0"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1A3A4A"/>
                            <Setter Property="BorderBrush" Value="{StaticResource NecCyanBrush}"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{StaticResource NeonCyan}" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#0A2A3A"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{StaticResource NeonCyan}" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="CyberButtonDanger" BasedOn="{StaticResource CyberButton}">
        <Setter Property="Foreground" Value="{StaticResource NecRedBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource NecRedBrush}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="{StaticResource NeonRed}" BlurRadius="8" ShadowDepth="0" Opacity="0"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="CyberNavButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="{StaticResource CyberFontBody}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="0" CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Rectangle x:Name="ActiveIndicator" Width="3" HorizontalAlignment="Left" Fill="{StaticResource NecCyanBrush}" RadiusX="1" RadiusY="1" Opacity="0" Margin="-8,2,0,2"/>
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1A2235"/>
                            <Setter TargetName="ActiveIndicator" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TextBox" x:Key="CyberTextBox">
        <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="{StaticResource CyberFontBody}"/>
        <Setter Property="CaretBrush" Value="{StaticResource NecCyanBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource NecCyanBrush}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="{StaticResource NeonCyan}" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ComboBox" x:Key="CyberComboBox">
        <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="{StaticResource CyberFontBody}"/>
    </Style>

    <Style TargetType="ProgressBar" x:Key="CyberProgress">
        <Setter Property="Height" Value="6"/>
        <Setter Property="Foreground" Value="{StaticResource NecCyanBrush}"/>
        <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style TargetType="ScrollViewer" x:Key="CyberScroll">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="CyberHeading">
        <Setter Property="Foreground" Value="{StaticResource NecCyanBrush}"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontFamily" Value="{StaticResource CyberFontHeading}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="{StaticResource NeonCyan}" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TextBlock" x:Key="CyberSubheading">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontFamily" Value="{StaticResource CyberFontBody}"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="CyberLabel">
        <Setter Property="Foreground" Value="{StaticResource NecCyanBrush}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontFamily" Value="{StaticResource CyberFontBody}"/>
    </Style>

    <Style TargetType="CheckBox" x:Key="CyberCheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource CyberFontBody}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="Border" x:Key="CyberCard">
        <Setter Property="Background" Value="{StaticResource BgPanelBrush}"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="{StaticResource NeonCyan}" BlurRadius="12" ShadowDepth="0" Opacity="0.15"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Storyboard x:Key="SlideInFromRight">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                          From="30" To="0" Duration="0:0:0.3">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <Storyboard x:Key="SlideInFromBottom">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                          From="20" To="0" Duration="0:0:0.25">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <Storyboard x:Key="FadeOut">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.15"/>
    </Storyboard>

    <Storyboard x:Key="NeonPulse" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                          From="0.15" To="0.5" Duration="0:0:2" AutoReverse="True">
            <DoubleAnimation.EasingFunction>
                <SineEase EasingMode="EaseInOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <Storyboard x:Key="GlitchFlicker" RepeatBehavior="Forever">
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity" Duration="0:0:4">
            <DiscreteDoubleKeyFrame Value="1" KeyTime="0:0:0"/>
            <DiscreteDoubleKeyFrame Value="1" KeyTime="0:0:2.1"/>
            <DiscreteDoubleKeyFrame Value="0.15" KeyTime="0:0:2.12"/>
            <DiscreteDoubleKeyFrame Value="0.95" KeyTime="0:0:2.14"/>
            <DiscreteDoubleKeyFrame Value="0.3" KeyTime="0:0:2.15"/>
            <DiscreteDoubleKeyFrame Value="1" KeyTime="0:0:2.17"/>
            <DiscreteDoubleKeyFrame Value="1" KeyTime="0:0:3.5"/>
            <DiscreteDoubleKeyFrame Value="0.1" KeyTime="0:0:3.51"/>
            <DiscreteDoubleKeyFrame Value="1" KeyTime="0:0:3.53"/>
        </DoubleAnimationUsingKeyFrames>
        <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Foreground).(SolidColorBrush.Color)">
            <DiscreteColorKeyFrame Value="#00F0FF" KeyTime="0:0:0"/>
            <DiscreteColorKeyFrame Value="#00F0FF" KeyTime="0:0:2.1"/>
            <DiscreteColorKeyFrame Value="#FF00FF" KeyTime="0:0:2.12"/>
            <DiscreteColorKeyFrame Value="#00F0FF" KeyTime="0:0:2.14"/>
        </ColorAnimationUsingKeyFrames>
    </Storyboard>

</ResourceDictionary>