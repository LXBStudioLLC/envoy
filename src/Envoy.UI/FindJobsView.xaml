<UserControl x:Class="Envoy.UI.FindJobsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0A0E17">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24">
            <TextBlock Text="&#x25C8; FIND JOBS" Style="{StaticResource CyberHeading}" Margin="0,0,0,4"/>
            <TextBlock Text="SANCTIONED DISCOVERY &#x2014; PUBLIC ATS FEEDS + WEB SEARCH, GHOST-SCORED" Style="{StaticResource CyberSubheading}" Margin="0,0,0,20"/>

            <!-- Search Controls -->
            <Border Background="#111827" CornerRadius="3" BorderBrush="#1A3A4A" BorderThickness="1" Padding="20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect Color="#00F0FF" BlurRadius="12" ShadowDepth="0" Opacity="0.15"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="&#x25C8; KEYWORDS" Foreground="#00F0FF" FontSize="11" FontFamily="{StaticResource CyberFontBody}" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtKeywords" Style="{StaticResource CyberTextBox}" Margin="0,0,0,12" AutomationProperties.Name="Search keywords"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="&#x25C8; LOCATION (OPTIONAL)" Foreground="#00F0FF" FontSize="11" FontFamily="{StaticResource CyberFontBody}" Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtLocation" Style="{StaticResource CyberTextBox}" AutomationProperties.Name="Location filter"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkRemote" Grid.Column="1" Content="Remote only" Foreground="#8892A4" VerticalAlignment="Bottom" Margin="0,0,0,6" FontFamily="{StaticResource CyberFontBody}"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button x:Name="BtnScanBoards" Content="&#x25C8; SCAN BOARDS" Click="BtnScanBoards_Click" Style="{StaticResource CyberButton}" Padding="20,10" Margin="0,0,12,0" AutomationProperties.Name="Scan public ATS boards"/>
                        <Button x:Name="BtnWebSearch" Content="&#x2316; WEB SEARCH" Click="BtnWebSearch_Click" Style="{StaticResource CyberButton}" Padding="20,10" AutomationProperties.Name="Search the web via Brave"/>
                    </StackPanel>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="SCAN BOARDS reads public company ATS feeds (no key). WEB SEARCH uses your Brave Search API key." Foreground="#5A6678" FontSize="10" FontFamily="{StaticResource CyberFontBody}" TextWrapping="Wrap" Grid.Column="0"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="12,0,0,0">
                            <TextBlock Text="SORT: " Foreground="#5A6678" FontSize="10" FontFamily="{StaticResource CyberFontBody}" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CmbSort" Style="{StaticResource CyberComboBox}" SelectionChanged="CmbSort_SelectionChanged" AutomationProperties.Name="Sort results">
                                <ComboBoxItem Content="Newest first" IsSelected="True"/>
                                <ComboBoxItem Content="Ghost score (high to low)"/>
                                <ComboBoxItem Content="Company (A-Z)"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="SCAN BOARDS reads public company ATS feeds (no key). WEB SEARCH uses your Brave Search API key." Foreground="#5A6678" FontSize="10" FontFamily="{StaticResource CyberFontBody}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Add Company -->
            <Border Background="#111827" CornerRadius="3" BorderBrush="#1A3A4A" BorderThickness="1" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="&#x25C8; ADD COMPANY" Foreground="#00F0FF" FontSize="12" FontWeight="Bold" FontFamily="{StaticResource CyberFontHeading}" Margin="0,0,0,8"/>
                    <TextBlock Text="Type a company name. Envoy probes 6 ATS platforms (Greenhouse, Lever, Ashby, Workable, Recruitee, SmartRecruiters) to find their public job board." Foreground="#5A6678" FontSize="10" FontFamily="{StaticResource CyberFontBody}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtAddCompany" Style="{StaticResource CyberTextBox}" Grid.Column="0" Margin="0,0,12,0" AutomationProperties.Name="Company name to discover"/>
                        <Button x:Name="BtnAddCompany" Content="&#x25C8; FIND BOARD" Click="BtnAddCompany_Click" Style="{StaticResource CyberButton}" Grid.Column="1" Padding="16,8"/>
                    </Grid>
                    <TextBlock x:Name="AddCompanyStatus" Text="" Foreground="#8892A4" FontSize="10" FontFamily="{StaticResource CyberFontBody}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Board List -->
            <Border Background="#0D1117" CornerRadius="3" BorderBrush="#1A3A4A" BorderThickness="1" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#x25C8; SCANNED BOARDS" Foreground="#00F0FF" FontSize="12" FontWeight="Bold" FontFamily="{StaticResource CyberFontHeading}"/>
                        <TextBlock x:Name="BoardCountLabel" Text="0 boards" Grid.Column="1" Foreground="#5A6678" FontSize="10" FontFamily="{StaticResource CyberFontBody}" VerticalAlignment="Center"/>
                    </Grid>
                    <ItemsControl x:Name="BoardList" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#111827" CornerRadius="2" Padding="8,4" Margin="0,0,0,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="11" Foreground="#E0E6F0" FontFamily="{StaticResource CyberFontBody}">
                                                <Run Text="{Binding Company, Mode=OneWay}"/><Run Text="  (" Foreground="#5A6678"/><Run Text="{Binding Ats, Mode=OneWay}" Foreground="#00F0FF"/><Run Text=")" Foreground="#5A6678"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Content="&#x2715;" Click="BtnRemoveBoard_Click" Tag="{Binding Id, Mode=OneWay}" Grid.Column="1" Background="Transparent" Foreground="#FF073A" BorderThickness="0" FontSize="10" Padding="6,2" Margin="4,0,0,0" AutomationProperties.Name="Remove this board"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="NoBoardsLabel" Text="No boards loaded. Built-in defaults will be used." Foreground="#5A6678" FontSize="10" FontFamily="{StaticResource CyberFontBody}" Visibility="Collapsed" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Brave Search API Key -->
            <Border Background="#0D1117" CornerRadius="3" BorderBrush="#1A3A4A" BorderThickness="1" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="&#x25C8; BRAVE SEARCH API KEY (OPTIONAL)" Foreground="#8892A4" FontSize="10" FontFamily="{StaticResource CyberFontBody}" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="TxtBraveKey" Grid.Column="0" Background="#0D1321" Foreground="#E0E6F0" BorderBrush="#1A3A4A" BorderThickness="1" Padding="8,6" FontFamily="{StaticResource CyberFontBody}" FontSize="12" Margin="0,0,12,0" AutomationProperties.Name="Brave Search API key"/>
                        <Button x:Name="BtnSaveKey" Grid.Column="1" Content="SAVE KEY" Click="BtnSaveKey_Click" Style="{StaticResource CyberButton}" Padding="14,8"/>
                    </Grid>
                    <TextBlock Text="Get a free key at api-dashboard.search.brave.com. Stored encrypted on this machine." Foreground="#5A6678" FontSize="10" FontFamily="{StaticResource CyberFontBody}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock x:Name="StatusText" Text="" Foreground="#8892A4" FontSize="12" FontFamily="{StaticResource CyberFontBody}" Margin="0,0,0,12" TextWrapping="Wrap"/>

            <ItemsControl x:Name="ResultsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1A2235" CornerRadius="3" BorderBrush="#1A3A4A" BorderThickness="1" Padding="14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding Title}" Foreground="#E0E6F0" FontSize="14" FontWeight="Bold" FontFamily="{StaticResource CyberFontBody}" TextWrapping="Wrap"/>
                                    <TextBlock Foreground="#8892A4" FontSize="11" FontFamily="{StaticResource CyberFontBody}" Margin="0,2,0,0" TextWrapping="Wrap">
                                        <Run Text="{Binding Company, Mode=OneWay}"/><Run Text="  &#x00B7;  "/><Run Text="{Binding Location, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Meta}" Foreground="#5A6678" FontSize="10" FontFamily="{StaticResource CyberFontBody}" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding Evidence}" Visibility="{Binding EvidenceVisibility}" Foreground="#FFE600" FontSize="10" FontFamily="{StaticResource CyberFontBody}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right">
                                    <Border Background="{Binding RiskBrush}" CornerRadius="2" Padding="8,3" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding RiskText}" Foreground="#0A0E17" FontSize="11" FontWeight="Bold" FontFamily="{StaticResource CyberFontHeading}"/>
                                    </Border>
                                    <Button Content="&#x25C8; VIEW" Tag="{Binding Url}" Click="BtnView_Click" Style="{StaticResource CyberButton}" Padding="14,5" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>